@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalProducts</div>
                    <div class="text-muted small">Toplam Ürün</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-tags"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalCategories</div>
                    <div class="text-muted small">Toplam Kategori</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-receipt"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalOrders</div>
                    <div class="text-muted small">Toplam Sipariş</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@ViewBag.PendingOrders</div>
                    <div class="text-muted small">Bekleyen Sipariş</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="bg-white rounded-3 border p-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="fw-semibold mb-0">Son Siparişler</h6>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary">
            Tümünü Gör
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Sipariş No</th>
                    <th>Müşteri</th>
                    <th>Tutar</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in (IEnumerable<ToptanciECommerce.Domain.Entities.Order>)ViewBag.RecentOrders)
                {
                    <tr>
                        <td><code>#@order.OrderNumber</code></td>
                        <td>
                            <div class="fw-semibold">@order.CustomerName</div>
                            <small class="text-muted">@order.CustomerCompany</small>
                        </td>
                        <td class="fw-semibold">@order.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td>
                            @{
                                var badgeClass = order.Status switch
                                {
                                    OrderStatus.Pending => "bg-warning text-dark",
                                    OrderStatus.PaymentSucceeded or OrderStatus.Processing => "bg-info",
                                    OrderStatus.Shipped => "bg-primary",
                                    OrderStatus.Delivered => "bg-success",
                                    OrderStatus.Cancelled or OrderStatus.PaymentFailed => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@order.Status</span>
                        </td>
                        <td class="text-muted small">@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Details"
                               asp-route-id="@order.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
