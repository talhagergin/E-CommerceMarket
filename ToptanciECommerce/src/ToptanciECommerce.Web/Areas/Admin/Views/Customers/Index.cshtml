@using ToptanciECommerce.Infrastructure.Data
@model IList<ApplicationUser>
@{
    ViewData["Title"] = "Müşteriler";
    var orderCounts = (Dictionary<string,int>)ViewBag.OrderCounts;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <span class="text-muted small">@Model.Count müşteri kayıtlı</span>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Yeni Müşteri Ekle
    </a>
</div>

<div class="bg-white rounded-3 border p-3 mb-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Ad, firma veya e-posta ile ara..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
        </div>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <div class="col-auto">
                <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
            </div>
        }
    </form>
</div>

<div class="bg-white rounded-3 border">
    <div class="p-3 border-bottom text-muted small">@Model.Count müşteri kayıtlı</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad / Firma</th>
                    <th>E-posta</th>
                    <th>Telefon</th>
                    <th>Şehir</th>
                    <th class="text-center">Sipariş</th>
                    <th class="text-end">Bakiye</th>
                    <th>Şifre</th>
                    <th>Durum</th>
                    <th>Kayıt Tarihi</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@user.FullName</div>
                            <small class="text-muted">@user.CompanyName</small>
                        </td>
                        <td class="small">@user.Email</td>
                        <td class="small">@(user.Phone ?? "—")</td>
                        <td class="small">@(user.City ?? "—")</td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">
                                @(orderCounts.GetValueOrDefault(user.Id, 0))
                            </span>
                        </td>
                        <td class="text-end fw-semibold @(user.Balance > 0 ? "text-danger" : user.Balance < 0 ? "text-success" : "text-muted")">
                            @user.Balance.ToString("N2") ₺
                            @if (user.Balance > 0)
                            {
                                <i class="bi bi-exclamation-circle ms-1 small" title="Borç var"></i>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(user.TempPassword))
                            {
                                <code class="small text-muted">@user.TempPassword</code>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (user.IsApproved)
                            {
                                <span class="badge bg-success">Onaylı</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Beklemede</span>
                            }
                        </td>
                        <td class="text-muted small">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
