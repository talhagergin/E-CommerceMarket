@model List<ToptanciECommerce.Application.DTOs.Category.CategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted small">@Model.Count ana kategori</span>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Yeni Kategori
    </a>
</div>

<div class="bg-white rounded-3 border">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th width="60">Görsel</th>
                    <th>Kategori Adı</th>
                    <th>Alt Kategoriler</th>
                    <th>Sıra</th>
                    <th>Durum</th>
                    <th width="120">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@MediaUrlHelper.ForHtmlImg(cat.ImageUrl, Configuration)" alt="@cat.Name"
                                     class="rounded" style="width:48px;height:48px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                     style="width:48px;height:48px;">
                                    <i class="bi bi-tags text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@cat.Name</div>
                            <small class="text-muted font-monospace">/@cat.Slug</small>
                        </td>
                        <td>
                            @if (cat.SubCategories.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var sub in cat.SubCategories)
                                    {
                                        <span class="badge bg-light text-dark border small">@sub.Name</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>@(cat.DisplayOrder ?? 0)</td>
                        <td>
                            @if (cat.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@cat.Id"
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('@cat.Name silinecek. Emin misiniz?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
