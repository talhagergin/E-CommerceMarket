@using ToptanciECommerce.Domain.Entities
@model IReadOnlyList<Payment>
@{
    ViewData["Title"] = "Ödemeler";
    var customers = (Dictionary<string,string>)ViewBag.Customers;
    string period = ViewBag.Period;
}

<!-- Period tabs -->
<div class="d-flex gap-2 mb-4 flex-wrap align-items-center justify-content-between">
    <div class="d-flex gap-2 flex-wrap">
        @foreach (var (key, label) in new[] { ("today","Bugün"), ("week","Bu Hafta"), ("month","Bu Ay"), ("all","Tümü") })
        {
            <a asp-action="Index" asp-route-period="@key"
               class="btn btn-sm @(period == key ? "btn-primary" : "btn-outline-secondary")">
                @label
            </a>
        }
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i> Ödeme Kaydet
    </a>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="bg-white rounded-3 border p-3 d-flex align-items-center gap-3">
            <div class="bg-success bg-opacity-10 rounded-2 p-2">
                <i class="bi bi-arrow-down-circle text-success fs-4"></i>
            </div>
            <div>
                <div class="text-muted small">Tahsilat</div>
                <div class="fs-5 fw-bold text-success">@((decimal)ViewBag.TotalIn).ToString("N2") ₺</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="bg-white rounded-3 border p-3 d-flex align-items-center gap-3">
            <div class="bg-danger bg-opacity-10 rounded-2 p-2">
                <i class="bi bi-arrow-up-circle text-danger fs-4"></i>
            </div>
            <div>
                <div class="text-muted small">İade</div>
                <div class="fs-5 fw-bold text-danger">@((decimal)ViewBag.TotalOut).ToString("N2") ₺</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="bg-white rounded-3 border p-3 d-flex align-items-center gap-3">
            <div class="bg-primary bg-opacity-10 rounded-2 p-2">
                <i class="bi bi-wallet2 text-primary fs-4"></i>
            </div>
            <div>
                <div class="text-muted small">Net Tahsilat</div>
                <div class="fs-5 fw-bold text-primary">@(((decimal)ViewBag.TotalIn - (decimal)ViewBag.TotalOut).ToString("N2")) ₺</div>
            </div>
        </div>
    </div>
</div>

<!-- Payments table -->
<div class="bg-white rounded-3 border">
    <div class="p-3 border-bottom text-muted small">
        @Model.Count ödeme kaydı — @(period == "today" ? "Bugün" : period == "week" ? "Bu Hafta" : period == "month" ? "Bu Ay" : "Tüm Zamanlar")
        @{
            DateTime from = ViewBag.From; DateTime to = ViewBag.To;
        }
        @if (period != "all")
        {
            <span class="ms-2">(@from.ToString("dd.MM.yyyy") — @(to.Date == DateTime.MaxValue.Date ? "Bugün" : to.ToString("dd.MM.yyyy")))</span>
        }
    </div>
    @if (!Model.Any())
    {
        <div class="p-5 text-center text-muted">Bu dönemde ödeme kaydı bulunamadı.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Müşteri</th>
                        <th>Tür</th>
                        <th>Yöntem</th>
                        <th>Sipariş</th>
                        <th class="text-end">Tutar</th>
                        <th>Not</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.OrderByDescending(x => x.PaymentDate))
                    {
                        <tr>
                            <td class="text-muted small">@p.PaymentDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-semibold">@(customers.GetValueOrDefault(p.CustomerId, "?"))</td>
                            <td>
                                @if (p.PaymentType == "Tahsilat")
                                {
                                    <span class="badge bg-success">Tahsilat</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">İade</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@p.PaymentMethod</span>
                            </td>
                            <td>
                                @if (p.OrderId.HasValue)
                                {
                                    <a asp-area="Admin" asp-controller="Orders" asp-action="Details"
                                       asp-route-id="@p.OrderId" class="text-decoration-none small">
                                        <i class="bi bi-receipt me-1"></i>#@p.OrderId
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-end fw-bold @(p.PaymentType == "Tahsilat" ? "text-success" : "text-danger")">
                                @(p.PaymentType == "İade" ? "-" : "+")@p.Amount.ToString("N2") ₺
                            </td>
                            <td class="text-muted small">@(p.Notes ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
