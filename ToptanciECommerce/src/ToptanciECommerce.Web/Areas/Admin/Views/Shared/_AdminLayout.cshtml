<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #1a1f36;
            --sidebar-hover: #252b48;
            --accent: #4f6ef7;
        }
        body { background: #f0f2f8; min-height: 100vh; }
        #sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0; left: 0; z-index: 1000;
            transition: transform .3s;
        }
        #sidebar .sidebar-brand {
            padding: 1.5rem 1.25rem;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        #sidebar .nav-link {
            color: rgba(255,255,255,.7);
            padding: .65rem 1.25rem;
            border-radius: .375rem;
            margin: .1rem .75rem;
            transition: background .2s, color .2s;
        }
        #sidebar .nav-link:hover,
        #sidebar .nav-link.active {
            background: var(--sidebar-hover);
            color: #fff;
        }
        #sidebar .nav-link i { width: 1.5rem; }
        #sidebar .nav-section {
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: rgba(255,255,255,.35);
            padding: 1rem 1.25rem .25rem;
        }
        #main { margin-left: var(--sidebar-width); }
        #topbar {
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: .75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .stat-card {
            background: #fff;
            border-radius: .75rem;
            padding: 1.5rem;
            border: 1px solid #e5e7eb;
        }
        .stat-card .stat-icon {
            width: 48px; height: 48px;
            border-radius: .5rem;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
        }
    </style>
</head>
<body>

<!-- Sidebar -->
<nav id="sidebar">
    <div class="sidebar-brand">
        <i class="bi bi-bag-heart-fill text-primary me-2"></i>
        ToptanciB2B Admin
    </div>

    <div class="pt-2">
        <span class="nav-section">Genel</span>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
           asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <span class="nav-section mt-3">Katalog</span>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")"
           asp-area="Admin" asp-controller="Products" asp-action="Index">
            <i class="bi bi-box-seam"></i> Ürünler
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")"
           asp-area="Admin" asp-controller="Categories" asp-action="Index">
            <i class="bi bi-tags"></i> Kategoriler
        </a>
        <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="StockPriceUpdate">
            <i class="bi bi-currency-dollar"></i> Fiyat / Stok Güncelle
        </a>

        <span class="nav-section mt-3">Satış</span>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")"
           asp-area="Admin" asp-controller="Orders" asp-action="Index">
            <i class="bi bi-receipt"></i> Siparişler
        </a>
        <a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Yeni Sipariş
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")"
           asp-area="Admin" asp-controller="Customers" asp-action="Index">
            <i class="bi bi-people"></i> Müşteriler
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")"
           asp-area="Admin" asp-controller="Payments" asp-action="Index">
            <i class="bi bi-cash-coin"></i> Ödemeler
        </a>

        <span class="nav-section mt-3">Sistem</span>
        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" target="_blank">
            <i class="bi bi-globe"></i> Siteyi Görüntüle
        </a>
        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline w-100">
            @Html.AntiForgeryToken()
            <button type="submit" class="nav-link border-0 bg-transparent w-100 text-start">
                <i class="bi bi-box-arrow-left"></i> Çıkış Yap
            </button>
        </form>
    </div>
</nav>

<!-- Main content -->
<div id="main">
    <!-- Top bar -->
    <div id="topbar">
        <h6 class="mb-0 fw-semibold text-dark">@ViewData["Title"]</h6>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small">@User.Identity?.Name</span>
            <span class="badge bg-primary">Admin</span>
        </div>
    </div>

    <!-- Page content -->
    <div class="p-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
