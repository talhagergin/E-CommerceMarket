@model CreateEditProductDto
@{
    ViewData["Title"] = "Ürün Düzenle: " + Model.Name;
    var existingImages = ViewBag.ExistingImages as List<ToptanciECommerce.Domain.Entities.ProductImage> ?? new();
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h6 class="fw-semibold mb-0">Ürün Düzenle</h6>
</div>

<div class="row">
    <div class="col-xl-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- Basic Info -->
            <div class="bg-white rounded-3 border p-4 mb-4">
                <h6 class="fw-semibold mb-3">Temel Bilgiler</h6>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label">Ürün Adı <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Ürün adını girin..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SKU" class="form-label">SKU <span class="text-danger">*</span></label>
                        <input asp-for="SKU" class="form-control" placeholder="ÜRN-001" />
                        <span asp-validation-for="SKU" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="ShortDescription" class="form-label">Kısa Açıklama</label>
                        <input asp-for="ShortDescription" class="form-control" placeholder="Maksimum 500 karakter..." />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Tam Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Kategori <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Pricing -->
            <div class="bg-white rounded-3 border p-4 mb-4">
                <h6 class="fw-semibold mb-3">Fiyatlandırma</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label">Liste Fiyatı (₺) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">₺</span>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="WholesalePrice" class="form-label">Toptan Fiyat (₺) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">₺</span>
                            <input asp-for="WholesalePrice" type="number" step="0.01" class="form-control" />
                        </div>
                        <span asp-validation-for="WholesalePrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TaxRate" class="form-label">KDV Oranı (%)</label>
                        <div class="input-group">
                            <input asp-for="TaxRate" type="number" step="1" class="form-control" />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stock -->
            <div class="bg-white rounded-3 border p-4 mb-4">
                <h6 class="fw-semibold mb-3">Stok Yönetimi</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="StockQuantity" class="form-label">Stok Adedi</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="MinOrderQuantity" class="form-label">Min. Sipariş</label>
                        <input asp-for="MinOrderQuantity" type="number" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="QuantityStep" class="form-label">Adım Miktarı</label>
                        <input asp-for="QuantityStep" type="number" class="form-control" />
                        <div class="form-text">Örn: 6 → 6, 12, 18...</div>
                    </div>
                </div>
            </div>

            <!-- Existing Images -->
            @if (existingImages.Any())
            {
                <div class="bg-white rounded-3 border p-4 mb-4">
                    <h6 class="fw-semibold mb-3">Mevcut Görseller</h6>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var img in existingImages)
                        {
                            <div class="position-relative" style="width:100px;">
                                <img src="@img.ImageUrl" alt="Ürün Görseli"
                                     class="img-thumbnail @(img.IsMain ? "border-primary border-2" : "")"
                                     style="width:100px;height:100px;object-fit:cover;" />
                                @if (img.IsMain)
                                {
                                    <span class="badge bg-primary position-absolute top-0 start-0 small">Ana</span>
                                }
                                <div class="mt-1 d-flex gap-1">
                                    <div class="form-check form-check-inline small p-0 m-0">
                                        <input class="form-check-input" type="radio"
                                               name="MainImageId" value="@img.Id"
                                               id="main_@img.Id"
                                               @(img.IsMain ? "checked" : "") />
                                        <label class="form-check-label small" for="main_@img.Id">Ana</label>
                                    </div>
                                </div>
                                <div class="form-check small mt-1">
                                    <input class="form-check-input border-danger" type="checkbox"
                                           name="DeleteImageIds" value="@img.Id" id="del_@img.Id" />
                                    <label class="form-check-label text-danger small" for="del_@img.Id">Sil</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- New Images -->
            <div class="bg-white rounded-3 border p-4 mb-4">
                <h6 class="fw-semibold mb-3">Yeni Görsel Ekle</h6>
                <div id="drop-zone"
                     class="border-2 border-dashed rounded-3 p-4 text-center text-muted"
                     style="border-color: #dee2e6; cursor: pointer;"
                     onclick="document.getElementById('imageInput').click()">
                    <i class="bi bi-cloud-upload fs-2 d-block mb-2"></i>
                    <div class="small">Görselleri sürükleyip bırakın veya tıklayın</div>
                </div>
                <input type="file" id="imageInput" name="NewImages" multiple accept="image/*" class="d-none" />
                <div id="image-preview" class="d-flex flex-wrap gap-2 mt-3"></div>
            </div>

            <!-- Flags -->
            <div class="bg-white rounded-3 border p-4 mb-4">
                <h6 class="fw-semibold mb-3">Görünürlük</h6>
                <div class="form-check form-switch mb-2">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Aktif (Sitede görünsün)</label>
                </div>
                <div class="form-check form-switch">
                    <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                    <label asp-for="IsFeatured" class="form-check-label">Öne Çıkan Ürün</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check2 me-1"></i> Değişiklikleri Kaydet
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const dropZone = document.getElementById('drop-zone');
    const imageInput = document.getElementById('imageInput');
    const previewContainer = document.getElementById('image-preview');

    ['dragenter', 'dragover'].forEach(e => {
        dropZone.addEventListener(e, ev => {
            ev.preventDefault();
            dropZone.style.borderColor = '#4f6ef7';
            dropZone.style.background = '#f0f4ff';
        });
    });
    ['dragleave', 'drop'].forEach(e => {
        dropZone.addEventListener(e, ev => {
            ev.preventDefault();
            dropZone.style.borderColor = '#dee2e6';
            dropZone.style.background = '';
        });
    });
    dropZone.addEventListener('drop', ev => addFiles(ev.dataTransfer.files));
    imageInput.addEventListener('change', () => addFiles(imageInput.files));

    function addFiles(files) {
        Array.from(files).forEach(file => {
            if (!file.type.startsWith('image/')) return;
            const reader = new FileReader();
            reader.onload = e => {
                const div = document.createElement('div');
                div.style.cssText = 'position:relative;width:90px;height:90px;';
                div.innerHTML = `
                    <img src="${e.target.result}" style="width:90px;height:90px;object-fit:cover;border-radius:8px;border:2px solid #dee2e6;">
                    <button type="button" onclick="this.parentElement.remove()"
                        style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;border:none;background:#ef4444;color:#fff;font-size:12px;cursor:pointer;">×</button>`;
                previewContainer.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
    }
</script>
}
