@model List<ToptanciECommerce.Application.DTOs.Product.ProductDto>
@{
    ViewData["Title"] = "Fiyat & Stok Güncelleme";
}

<div class="bg-white rounded-3 border p-3 mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label text-muted small">Kategoriye Göre Filtrele</label>
            <select name="categoryId" asp-items="ViewBag.Categories" class="form-select"
                    onchange="this.form.submit()">
                <option value="">-- Tüm Ürünler --</option>
            </select>
        </div>
    </form>
</div>

<form asp-action="BulkUpdatePricesStock" method="post">
    @Html.AntiForgeryToken()
    <div class="bg-white rounded-3 border">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ürün Adı</th>
                        <th width="80">SKU</th>
                        <th width="140">Liste Fiyatı (₺)</th>
                        <th width="140">Toptan Fiyatı (₺)</th>
                        <th width="110">Stok</th>
                        <th width="80">Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <input type="hidden" name="updates[@i].Id" value="@Model[i].Id" />
                        <tr>
                            <td>
                                <div class="fw-semibold">@Model[i].Name</div>
                            </td>
                            <td><code>@Model[i].SKU</code></td>
                            <td>
                                <input type="number" name="updates[@i].Price"
                                       value="@Model[i].Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                       step="0.01" class="form-control form-control-sm" />
                            </td>
                            <td>
                                <input type="number" name="updates[@i].WholesalePrice"
                                       value="@Model[i].WholesalePrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                       step="0.01" class="form-control form-control-sm text-primary fw-semibold" />
                            </td>
                            <td>
                                <input type="number" name="updates[@i].StockQuantity"
                                       value="@Model[i].StockQuantity"
                                       class="form-control form-control-sm @(Model[i].StockQuantity <= 5 ? "border-danger" : "")" />
                            </td>
                            <td>
                                @if (Model[i].IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success px-4">
            <i class="bi bi-floppy me-1"></i> Tümünü Kaydet (@Model.Count ürün)
        </button>
    </div>
</form>
