{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=toptanci;Username=postgres;Password=postgres"
  },
  // R2: Endpoint = S3 API URL (https://<accountid>.r2.cloudflarestorage.com). PublicUrl = browser-facing URL
