  "CloudflareR2": {
    "Endpoint": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "BucketName": "",
    "PublicUrl": "",
    "DeliverImagesViaApp": true
  },
  "ShowDetailedErrors": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "GlobalException": "Error",
      "ToptanciECommerce.Infrastructure.Services.R2ImageService": "Information"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "SiteName": "ToptanciB2B",
    "SiteUrl": "https://localhost:7100",
    "ContactEmail": "info@toptanci.com",
