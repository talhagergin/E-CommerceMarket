@using ToptanciECommerce.Domain.Entities
@{
    ViewData["Title"] = "Ana Sayfa";
    var categories = (IReadOnlyList<Category>)ViewBag.Categories;
    var featured = (IReadOnlyList<Product>)ViewBag.FeaturedProducts;
}

<!-- Hero -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-5 fw-bold mb-3 hero-title">B2B Toptan Alışverişin Yeni Adresi</h1>
                <p class="lead mb-4 opacity-75">
                    Binlerce ürün, rekabetçi toptan fiyatlar ve hızlı teslimat. İşletmenize değer katın.
                </p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-warning btn-lg fw-semibold px-4">
                    <i class="bi bi-grid me-2"></i> Ürünleri İncele
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
@if (categories.Any())
{
    <section class="py-5 bg-light border-bottom">
        <div class="container">
            <h2 class="h5 fw-bold mb-4">Kategoriler</h2>
            <div class="category-nav-scroll home-categories pb-1">
                <div class="category-nav-inner gap-2">
                <a asp-controller="Products" asp-action="Index" class="category-badge">
                    <i class="bi bi-grid"></i> Tümü
                </a>
                @foreach (var cat in categories)
                {
                    <a asp-controller="Products" asp-action="Index"
                       asp-route-categoryId="@cat.Id" class="category-badge">
                        @cat.Name
                        @if (cat.SubCategories.Any())
                        {
                            <span class="text-muted">(@cat.SubCategories.Count)</span>
                        }
                    </a>
                }
                </div>
            </div>
        </div>
    </section>
}

<!-- Featured Products -->
@if (featured.Any())
{
    <section class="py-5">
        <div class="container">
            <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between gap-2 mb-4">
                <h2 class="h5 fw-bold mb-0">Öne Çıkan Ürünler</h2>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary btn-sm align-self-start align-self-sm-auto">
                    Tümünü Gör <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-4">
                @foreach (var p in featured)
                {
                    var mainImg = p.Images.FirstOrDefault(i => i.IsMain) ?? p.Images.FirstOrDefault();
                    <div class="col">
                        <div class="product-card h-100">
                            <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug">
                                <div class="product-img-wrap">
                                    @if (mainImg != null)
                                    {
                                        <img src="@MediaUrlHelper.ForHtmlImg(mainImg.ImageUrl, Configuration)" alt="@p.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100 position-absolute inset-0">
                                            <i class="bi bi-image fs-1 text-muted"></i>
                                        </div>
                                    }
                                </div>
                            </a>
                            <div class="product-body">
                                <div class="product-sku mb-1">@p.SKU</div>
                                <a asp-controller="Products" asp-action="Detail" asp-route-slug="@p.Slug"
                                   class="text-decoration-none text-dark">
                                    <div class="product-name mb-2">@p.Name</div>
                                </a>
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="wholesale-price">@p.WholesalePrice.ToString("N2") ₺</span>
                                    @if (p.Price != p.WholesalePrice)
                                    {
                                        <span class="list-price">@p.Price.ToString("N2") ₺</span>
                                    }
                                </div>
                                <div class="qty-stepper mb-2" data-product-id="@p.Id"
                                     data-step="@p.QuantityStep" data-min="@p.MinOrderQuantity">
                                    <button type="button" onclick="stepDown(this)">−</button>
                                    <input type="number" value="@p.MinOrderQuantity" min="@p.MinOrderQuantity" step="@p.QuantityStep" />
                                    <button type="button" onclick="stepUp(this)">+</button>
                                </div>
                                <button class="btn btn-primary btn-sm w-100"
                                        onclick="addToCartFromCard(this)">
                                    <i class="bi bi-cart-plus me-1"></i> Sepete Ekle
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Value Props -->
<section class="bg-light py-5 border-top">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <i class="bi bi-truck fs-2 text-primary d-block mb-2"></i>
                <h6 class="fw-semibold">Hızlı Teslimat</h6>
                <p class="text-muted small mb-0">İstanbul içi aynı gün, yurt içi 2 iş günü</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-shield-check fs-2 text-success d-block mb-2"></i>
                <h6 class="fw-semibold">Güvenli Alışveriş</h6>
                <p class="text-muted small mb-0">SSL şifreli ödeme, Iyzico güvencesi</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-box-seam fs-2 text-warning d-block mb-2"></i>
                <h6 class="fw-semibold">Toptan Fiyat</h6>
                <p class="text-muted small mb-0">Minimum sipariş avantajlı fiyatlar</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-headset fs-2 text-info d-block mb-2"></i>
                <h6 class="fw-semibold">7/24 Destek</h6>
                <p class="text-muted small mb-0">Uzman ekibimiz her zaman yanınızda</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
function stepDown(btn) {
    const wrap = btn.closest('.qty-stepper');
    const input = wrap.querySelector('input');
    const step = parseInt(wrap.dataset.step) || 1;
    const min = parseInt(wrap.dataset.min) || 1;
    const newVal = Math.max(min, parseInt(input.value) - step);
    input.value = newVal;
}
function stepUp(btn) {
    const wrap = btn.closest('.qty-stepper');
    const input = wrap.querySelector('input');
    const step = parseInt(wrap.dataset.step) || 1;
    input.value = parseInt(input.value) + step;
}
async function addToCartFromCard(btn) {
    const wrap = btn.closest('.product-body');
    const stepper = wrap.querySelector('.qty-stepper');
    const productId = parseInt(stepper.dataset.productId);
    const quantity = parseInt(stepper.querySelector('input').value);
    btn.disabled = true;
    await addToCart(productId, quantity);
    btn.disabled = false;
}
</script>
}
