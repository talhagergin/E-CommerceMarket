@using ToptanciECommerce.Domain.Entities
@using ToptanciECommerce.Domain.Enums
@model IReadOnlyList<Order>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item active">Siparişlerim</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-4">
    <div class="d-flex flex-wrap align-items-center gap-2 gap-md-3 mb-4">
        <h4 class="fw-bold mb-0">Siparişlerim</h4>
        <span class="badge bg-primary">@Model.Count sipariş</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-receipt fs-1 d-block mb-3 text-muted opacity-25"></i>
            <h5 class="text-muted">Henüz siparişiniz bulunmuyor.</h5>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2">
                Ürünlere Göz At
            </a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-3 border">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sipariş No</th>
                            <th>Ürünler</th>
                            <th class="text-end">Toplam</th>
                            <th>Durum</th>
                            <th>Tarih</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>
                                    <code class="fw-semibold text-primary">#@order.OrderNumber</code>
                                </td>
                                <td>
                                    <div class="small text-muted">
                                        @order.OrderItems.Count kalem ürün
                                    </div>
                                    <div class="small text-truncate" style="max-width:200px;">
                                        @string.Join(", ", order.OrderItems.Take(2).Select(i => i.ProductName))
                                        @if (order.OrderItems.Count > 2)
                                        {
                                            <span class="text-muted"> +@(order.OrderItems.Count - 2) daha</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-end fw-semibold">
                                    @order.TotalAmount.ToString("N2") ₺
                                </td>
                                <td>
                                    <span class="badge @order.Status.BadgeClass()">
                                        @order.Status.ToTurkish()
                                    </span>
                                </td>
                                <td class="text-muted small">
                                    @order.CreatedAt.ToString("dd.MM.yyyy")<br />
                                    <span class="text-muted">@order.CreatedAt.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Detail" asp-route-id="@order.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i> Detay
                                        </a>
                                        <a asp-action="DownloadPdf" asp-route-id="@order.Id"
                                           class="btn btn-sm btn-outline-secondary" title="PDF İndir">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
