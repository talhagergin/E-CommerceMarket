@using ToptanciECommerce.Application.DTOs.Order
@model ShippingInfoDto
@{
    ViewData["Title"] = "Sipariş Bilgileri";
    var cart = (ToptanciECommerce.Application.DTOs.Cart.CartDto)ViewBag.Cart;
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Sepetim</a></li>
                <li class="breadcrumb-item active">Sipariş Bilgileri</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">

        <!-- Form -->
        <div class="col-lg-7">
            <h5 class="fw-bold mb-4"><i class="bi bi-truck me-2 text-primary"></i>Teslimat Bilgileri</h5>

            <form asp-action="OrderInfo" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <div class="bg-white rounded-3 border p-4 mb-3">
                    <h6 class="fw-semibold mb-3 text-muted">İletişim</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CustomerName" class="form-label">Ad Soyad <span class="text-danger">*</span></label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Ad Soyad" />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CustomerCompany" class="form-label">Firma Adı <span class="text-danger">*</span></label>
                            <input asp-for="CustomerCompany" class="form-control" placeholder="Firma adı" />
                            <span asp-validation-for="CustomerCompany" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CustomerEmail" class="form-label">E-posta <span class="text-danger">*</span></label>
                            <input asp-for="CustomerEmail" type="email" class="form-control" />
                            <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CustomerPhone" class="form-label">Telefon</label>
                            <input asp-for="CustomerPhone" class="form-control" placeholder="0555 000 00 00" />
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3 border p-4 mb-3">
                    <h6 class="fw-semibold mb-3 text-muted">Teslimat Adresi</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">Adres <span class="text-danger">*</span></label>
                            <textarea asp-for="Address" class="form-control" rows="2"
                                      placeholder="Mahalle, sokak, bina no..."></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="District" class="form-label">İlçe <span class="text-danger">*</span></label>
                            <input asp-for="District" class="form-control" />
                            <span asp-validation-for="District" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label">Şehir <span class="text-danger">*</span></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PostalCode" class="form-label">Posta Kodu</label>
                            <input asp-for="PostalCode" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Sipariş Notu</label>
                            <textarea asp-for="Notes" class="form-control" rows="2"
                                      placeholder="Varsa özel talimatlarınız..."></textarea>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 py-3">
                    <i class="bi bi-file-earmark-pdf me-2"></i>
                    Siparişi Oluştur ve PDF İndir
                </button>
                <div class="text-center text-muted small mt-2">
                    Sipariş oluşturulduktan sonra PDF otomatik indirilecek.
                </div>
            </form>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-5">
            <h5 class="fw-bold mb-4"><i class="bi bi-cart3 me-2 text-primary"></i>Sipariş Özeti</h5>
            <div class="bg-white rounded-3 border">
                @foreach (var item in cart.Items)
                {
                    <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@MediaUrlHelper.ForHtmlImg(item.ImageUrl, Configuration)" alt="@item.ProductName"
                                 class="rounded-2 flex-shrink-0"
                                 style="width:56px;height:56px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="bg-light rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:56px;height:56px;">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        }
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold small text-truncate">@item.ProductName</div>
                            <div class="text-muted small">@item.Quantity adet × @item.UnitPrice.ToString("N2") ₺</div>
                        </div>
                        <div class="fw-bold text-primary small flex-shrink-0">@item.LineTotal.ToString("N2") ₺</div>
                    </div>
                }
                <div class="p-3">
                    <div class="d-flex justify-content-between text-muted small mb-1">
                        <span>Ara Toplam</span>
                        <span>@cart.SubTotal.ToString("N2") ₺</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted small mb-2">
                        <span>KDV</span>
                        <span>@cart.TaxAmount.ToString("N2") ₺</span>
                    </div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Genel Toplam</span>
                        <span class="text-primary fs-5">@cart.Total.ToString("N2") ₺</span>
                    </div>
                </div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-3">
                <i class="bi bi-arrow-left me-1"></i> Sepete Geri Dön
            </a>
        </div>
    </div>
</div>
