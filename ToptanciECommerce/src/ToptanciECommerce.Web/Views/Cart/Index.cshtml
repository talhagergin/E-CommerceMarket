@model CartDto
@{
    ViewData["Title"] = "Sepetim";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item active">Sepetim</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x fs-1 text-muted d-block mb-3 opacity-25"></i>
            <h4 class="text-muted">Sepetiniz boş</h4>
            <p class="text-muted">Ürünleri inceleyerek sepetinize ekleyebilirsiniz.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2">
                <i class="bi bi-grid me-2"></i> Ürünlere Git
            </a>
        </div>
    }
    else
    {
        <div class="row g-4 align-items-start">

            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-cart3 me-2 text-primary"></i>
                        Sepetim <span class="badge bg-primary ms-1">@Model.TotalQuantity adet</span>
                    </h5>
                    <form asp-action="Clear" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Sepeti tamamen temizlemek istediğinizden emin misiniz?')">
                            <i class="bi bi-trash me-1"></i> Sepeti Temizle
                        </button>
                    </form>
                </div>

                <div class="bg-white rounded-3 border" id="cartItemsContainer">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-row d-flex align-items-center gap-3 p-3 border-bottom"
                             id="row-@item.ProductId">
                            <!-- Image -->
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@MediaUrlHelper.ForHtmlImg(item.ImageUrl, Configuration)" alt="@item.ProductName"
                                         class="rounded-2"
                                         style="width:72px;height:72px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded-2 d-flex align-items-center justify-content-center"
                                         style="width:72px;height:72px;">
                                        <i class="bi bi-image text-muted fs-4"></i>
                                    </div>
                                }
                            </div>

                            <!-- Info -->
                            <div class="flex-grow-1 min-w-0">
                                <a asp-controller="Products" asp-action="Detail"
                                   asp-route-slug="@item.ProductSlug"
                                   class="text-decoration-none text-dark fw-semibold">
                                    @item.ProductName
                                </a>
                                <div class="text-muted small font-monospace">@item.SKU</div>
                                <div class="text-muted small">
                                    Birim: <strong>@item.UnitPrice.ToString("N2") ₺</strong>
                                    · KDV: %@item.TaxRate
                                </div>
                            </div>

                            <!-- Qty Stepper -->
                            <div class="flex-shrink-0">
                                <div class="qty-stepper"
                                     data-product-id="@item.ProductId"
                                     data-step="@item.QuantityStep"
                                     data-min="@item.MinOrderQuantity"
                                     data-stock="@item.StockQuantity">
                                    <button type="button" onclick="cartStepDown(this)">−</button>
                                    <input type="number"
                                           value="@item.Quantity"
                                           min="@item.MinOrderQuantity"
                                           step="@item.QuantityStep"
                                           onchange="cartUpdateQty(this)"
                                           style="width:65px;" />
                                    <button type="button" onclick="cartStepUp(this)">+</button>
                                </div>
                            </div>

                            <!-- Line Total -->
                            <div class="flex-shrink-0 text-end" style="min-width:90px;">
                                <div class="fw-bold text-primary fs-6 line-total"
                                     data-product-id="@item.ProductId">
                                    @item.LineTotal.ToString("N2") ₺
                                </div>
                                <div class="text-muted small">KDV hariç</div>
                            </div>

                            <!-- Remove -->
                            <div class="flex-shrink-0">
                                <button class="btn btn-sm btn-outline-danger"
                                        onclick="cartRemove(@item.ProductId)"
                                        title="Kaldır">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <a asp-controller="Products" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i> Alışverişe Devam Et
                    </a>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="bg-white rounded-3 border p-4 sticky-top" style="top:80px;">
                    <h6 class="fw-bold mb-3">Sipariş Özeti</h6>

                    <div class="d-flex justify-content-between mb-2 text-muted small">
                        <span>Ara Toplam</span>
                        <span id="summarySubTotal">@Model.SubTotal.ToString("N2") ₺</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted small">
                        <span>KDV Toplam</span>
                        <span id="summaryTaxAmount">@Model.TaxAmount.ToString("N2") ₺</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold">Genel Toplam</span>
                        <span class="fw-bold fs-5 text-primary" id="summaryTotal">@Model.Total.ToString("N2") ₺</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-action="OrderInfo" class="btn btn-primary w-100 mb-2 py-2 fw-semibold">
                            <i class="bi bi-check2-circle me-2"></i> Sipariş Oluştur ve PDF İndir
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           asp-route-returnUrl="/Cart/OrderInfo"
                           class="btn btn-primary w-100 mb-2 py-2 fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Sipariş İçin Giriş Yapın
                        </a>
                        <div class="alert alert-warning py-2 small mt-2">
                            <i class="bi bi-lock me-1"></i>
                            Sipariş verebilmek için giriş yapmanız gerekmektedir.
                        </div>
                    }
                    <div class="text-center text-muted small mt-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Teslimat bilgilerini doldurun, sipariş oluşsun ve PDF indirin.
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
// ── Quantity helpers ──────────────────────────────────────────────────────────
function cartStepDown(btn) {
    const wrap = btn.closest('.qty-stepper');
    const input = wrap.querySelector('input');
    const step = parseInt(wrap.dataset.step) || 1;
    const min  = parseInt(wrap.dataset.min)  || 1;
    const newVal = Math.max(min, parseInt(input.value) - step);
    if (newVal !== parseInt(input.value)) {
        input.value = newVal;
        cartUpdateQty(input);
    }
}

function cartStepUp(btn) {
    const wrap  = btn.closest('.qty-stepper');
    const input = wrap.querySelector('input');
    const step  = parseInt(wrap.dataset.step) || 1;
    const stock = parseInt(wrap.dataset.stock) || 9999;
    const newVal = Math.min(stock, parseInt(input.value) + step);
    if (newVal !== parseInt(input.value)) {
        input.value = newVal;
        cartUpdateQty(input);
    }
}

async function cartUpdateQty(input) {
    const wrap = input.closest('.qty-stepper');
    const productId = parseInt(wrap.dataset.productId);
    const quantity  = parseInt(input.value);

    const res = await fetch('/Cart/Update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity })
    });

    if (res.ok) {
        const data = await res.json();
        updateTotals(data, productId);
        updateCartBadge();
    }
}

async function cartRemove(productId) {
    const res = await fetch('/Cart/Remove', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId })
    });

    if (res.ok) {
        const data = await res.json();
        const row = document.getElementById('row-' + productId);
        if (row) {
            row.style.transition = 'opacity .3s, max-height .3s';
            row.style.opacity = '0';
            row.style.overflow = 'hidden';
            setTimeout(() => {
                row.remove();
                updateTotals(data, null);
                updateCartBadge();
                if (data.count === 0) location.reload();
            }, 300);
        }
    }
}

function updateTotals(data, productId) {
    document.getElementById('summarySubTotal').textContent  = data.subTotal  + ' ₺';
    document.getElementById('summaryTaxAmount').textContent = data.taxAmount + ' ₺';
    document.getElementById('summaryTotal').textContent     = data.total     + ' ₺';
    if (productId && data.lineTotal) {
        const lineTotalEl = document.querySelector(`.line-total[data-product-id="${productId}"]`);
        if (lineTotalEl) lineTotalEl.textContent = data.lineTotal + ' ₺';
    }
}
</script>
}
