@using ToptanciECommerce.Domain.Entities
@model IReadOnlyList<Product>
@{
    ViewData["Title"] = ViewBag.SelectedCategoryName ?? "Tüm Ürünler";
    var categories = (IReadOnlyList<Category>)ViewBag.Categories;
    int totalCount  = (int)ViewBag.TotalCount;
    int totalPages  = (int)ViewBag.TotalPages;
    int currentPage = (int)ViewBag.Page;
    int? selCatId   = ViewBag.SelectedCategoryId as int?;
    string? search  = ViewBag.Search as string;
    string? sortBy  = ViewBag.SortBy as string;
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                @if (selCatId.HasValue && ViewBag.SelectedCategoryName != null)
                {
                    <li class="breadcrumb-item active">@ViewBag.SelectedCategoryName</li>
                }
                else
                {
                    <li class="breadcrumb-item active">Tüm Ürünler</li>
                }
            </ol>
        </nav>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="bg-white rounded-3 border p-3">
                <h6 class="fw-bold mb-3">Kategoriler</h6>
                <ul class="list-unstyled mb-0">
                    <li>
                        <a asp-action="Index" asp-route-search="@search"
                           class="d-block py-1 px-2 rounded text-decoration-none @(selCatId == null ? "fw-bold text-primary" : "text-dark")">
                            <i class="bi bi-grid-fill me-1 small"></i> Tüm Ürünler
                            <span class="float-end text-muted small">@totalCount</span>
                        </a>
                    </li>
                    @foreach (var cat in categories)
                    {
                        <li class="mt-1">
                            <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-search="@search"
                               class="d-block py-1 px-2 rounded text-decoration-none
                                      @(selCatId == cat.Id ? "fw-bold text-primary bg-primary bg-opacity-10" : "text-dark")">
                                <i class="bi bi-folder me-1 small"></i> @cat.Name
                            </a>
                            @if (cat.SubCategories.Any())
                            {
                                <ul class="list-unstyled ps-3 mb-0">
                                    @foreach (var sub in cat.SubCategories)
                                    {
                                        <li>
                                            <a asp-action="Index" asp-route-categoryId="@sub.Id" asp-route-search="@search"
                                               class="d-block py-1 px-2 rounded text-decoration-none small
                                                      @(selCatId == sub.Id ? "fw-semibold text-primary bg-primary bg-opacity-10" : "text-secondary")">
                                                @sub.Name
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">

            <!-- Toolbar -->
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3 flex-wrap">
                <div class="text-muted small">
                    <strong>@totalCount</strong> ürün bulundu
                    @if (!string.IsNullOrEmpty(search))
                    {
                        <span>— "<em>@search</em>" araması</span>
                        <a asp-action="Index" asp-route-categoryId="@selCatId" class="ms-2 text-danger small">
                            <i class="bi bi-x-circle"></i> Temizle
                        </a>
                    }
                </div>
                <div class="d-flex gap-2">
                    <!-- Search -->
                    <form asp-action="Index" method="get" class="d-flex gap-1">
                        @if (selCatId.HasValue)
                        {
                            <input type="hidden" name="categoryId" value="@selCatId" />
                        }
                        <input type="text" name="search" value="@search"
                               class="form-control form-control-sm" placeholder="Ürün ara..." style="width:180px;" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                    <!-- Sort -->
                    <form asp-action="Index" method="get" id="sortForm">
                        @if (selCatId.HasValue)
                        {
                            <input type="hidden" name="categoryId" value="@selCatId" />
                        }
                        @if (!string.IsNullOrEmpty(search))
                        {
                            <input type="hidden" name="search" value="@search" />
                        }
                        <select name="sortBy" class="form-select form-select-sm"
                                onchange="document.getElementById('sortForm').submit()">
                            <option value="" selected="@(sortBy == null)">Varsayılan Sıralama</option>
                            <option value="name_asc" selected="@(sortBy == "name_asc")">Ad (A-Z)</option>
                            <option value="price_asc" selected="@(sortBy == "price_asc")">Fiyat (Ucuz → Pahalı)</option>
                            <option value="price_desc" selected="@(sortBy == "price_desc")">Fiyat (Pahalı → Ucuz)</option>
                            <option value="newest" selected="@(sortBy == "newest")">En Yeni</option>
                        </select>
                    </form>
                </div>
            </div>

            <!-- Grid -->
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-25"></i>
                    <h5>Bu kategoride ürün bulunamadı.</h5>
                    <a asp-action="Index" class="btn btn-outline-primary mt-2">Tüm ürünlere dön</a>
                </div>
            }
            else
            {
                <div class="row row-cols-2 row-cols-md-3 row-cols-xl-3 g-3">
                    @foreach (var p in Model)
                    {
                        var mainImg = p.Images.FirstOrDefault(i => i.IsMain) ?? p.Images.FirstOrDefault();
                        <div class="col">
                            <div class="product-card h-100">
                                <a asp-action="Detail" asp-route-slug="@p.Slug">
                                    <div class="product-img-wrap">
                                        @if (mainImg != null)
                                        {
                                            <img src="@MediaUrlHelper.ForHtmlImg(mainImg.ImageUrl, Configuration)" alt="@p.Name" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center justify-content-center h-100 position-absolute inset-0">
                                                <i class="bi bi-image fs-1 text-muted opacity-25"></i>
                                            </div>
                                        }
                                    </div>
                                </a>
                                <div class="product-body">
                                    <div class="product-sku mb-1">@p.SKU</div>
                                    <a asp-action="Detail" asp-route-slug="@p.Slug" class="text-decoration-none text-dark">
                                        <div class="product-name mb-2 text-truncate" title="@p.Name">@p.Name</div>
                                    </a>
                                    @if (!string.IsNullOrEmpty(p.ShortDescription))
                                    {
                                        <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@p.ShortDescription</p>
                                    }
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <span class="wholesale-price">@p.WholesalePrice.ToString("N2") ₺</span>
                                        @if (p.Price > p.WholesalePrice)
                                        {
                                            <span class="list-price">@p.Price.ToString("N2") ₺</span>
                                        }
                                    </div>
                                    <div class="text-muted small mb-2">
                                        Min: @p.MinOrderQuantity adet
                                        @if (p.StockQuantity <= 10 && p.StockQuantity > 0)
                                        {
                                            <span class="text-warning ms-2"><i class="bi bi-exclamation-triangle"></i> Son @p.StockQuantity</span>
                                        }
                                        else if (p.StockQuantity == 0)
                                        {
                                            <span class="text-danger ms-2">Stokta yok</span>
                                        }
                                    </div>
                                    <div class="qty-stepper mb-2" data-product-id="@p.Id"
                                         data-step="@p.QuantityStep" data-min="@p.MinOrderQuantity">
                                        <button type="button" onclick="stepDown(this)">−</button>
                                        <input type="number" value="@p.MinOrderQuantity"
                                               min="@p.MinOrderQuantity" step="@p.QuantityStep" />
                                        <button type="button" onclick="stepUp(this)">+</button>
                                    </div>
                                    <button class="btn btn-primary btn-sm w-100"
                                            onclick="addToCartFromCard(this)"
                                            @(p.StockQuantity == 0 ? "disabled" : "")>
                                        <i class="bi bi-cart-plus me-1"></i>
                                        @(p.StockQuantity == 0 ? "Stokta Yok" : "Sepete Ekle")
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @if (currentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(currentPage - 1)"
                                       asp-route-categoryId="@selCatId"
                                       asp-route-search="@search"
                                       asp-route-sortBy="@sortBy">‹</a>
                                </li>
                            }
                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-categoryId="@selCatId"
                                       asp-route-search="@search"
                                       asp-route-sortBy="@sortBy">@i</a>
                                </li>
                            }
                            @if (currentPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(currentPage + 1)"
                                       asp-route-categoryId="@selCatId"
                                       asp-route-search="@search"
                                       asp-route-sortBy="@sortBy">›</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function stepDown(btn) {
    const wrap = btn.closest('.qty-stepper');
    const input = wrap.querySelector('input');
    const step = parseInt(wrap.dataset.step) || 1;
    const min = parseInt(wrap.dataset.min) || 1;
    input.value = Math.max(min, parseInt(input.value) - step);
}
function stepUp(btn) {
    const wrap = btn.closest('.qty-stepper');
    const input = wrap.querySelector('input');
    const step = parseInt(wrap.dataset.step) || 1;
    input.value = parseInt(input.value) + step;
}
async function addToCartFromCard(btn) {
    const wrap = btn.closest('.product-body');
    const stepper = wrap.querySelector('.qty-stepper');
    const productId = parseInt(stepper.dataset.productId);
    const quantity = parseInt(stepper.querySelector('input').value);
    btn.disabled = true;
    await addToCart(productId, quantity);
    btn.disabled = false;
}
</script>
}
