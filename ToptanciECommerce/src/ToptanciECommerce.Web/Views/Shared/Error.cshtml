@model ToptanciECommerce.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}
<div class="container py-5 text-center">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3rem;"></i>
    <h1 class="mt-3">Bir hata oluştu</h1>
    <p class="text-muted">Üzgünüz, bir sorun yaşandı. Lütfen tekrar deneyin.</p>
    @if (Model?.ShowRequestId == true)
    {
        <p class="text-muted small mb-0">İstek kimliği (loglarda arayın): <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Ana Sayfaya Dön</a>
</div>
